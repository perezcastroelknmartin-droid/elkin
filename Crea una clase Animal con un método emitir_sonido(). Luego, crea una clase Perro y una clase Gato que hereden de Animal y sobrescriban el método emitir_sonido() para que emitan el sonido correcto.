class Animal:
    def emitir_sonido(self):
        print("El animal hace un sonido.")

class Perro(Animal):
    def emitir_sonido(self):
        print("Guau")

class Gato(Animal):
    def emitir_sonido(self):
        print("Miau")

perro = Perro()
gato = Gato()

perro.emitir_sonido()
gato.emitir_sonido()
